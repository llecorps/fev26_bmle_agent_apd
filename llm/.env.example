# Modèle de configuration du serveur LLM.
# Copier en llm/.env (gitignoré) et renseigner les valeurs réelles :
#   cp llm/.env.example llm/.env
#
# Le token Hugging Face n'est nécessaire que pour les modèles "gated".
# mlx-community/Mistral-7B-Instruct-v0.3-4bit est public : token optionnel.
# Générer un token : https://huggingface.co/settings/tokens (scope "read").

HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optionnel : surcharge du modèle et du port servis par vllm-mlx.
# MODEL=mlx-community/Mistral-7B-Instruct-v0.3-4bit
# PORT=8000
