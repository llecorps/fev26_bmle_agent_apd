# Configuration du serveur LLM (Ollama).
# Ollama est lancé automatiquement par docker-compose (service ollama).
# Pour un usage hors Docker, installer Ollama : https://ollama.com
# puis lancer : ollama pull mistral:7b

# Optionnel : surcharge de l'URL et du modèle Ollama.
# LLM_URL=http://localhost:11434/v1/chat/completions
# LLM_MODEL=mistral:7b
