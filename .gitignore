.venv/
__pycache__/
*.pyc
.pytest_cache/
.DS_Store
.cache/

# Secrets : tokens, credentials. Ne JAMAIS commiter.
.env
*/.env
!*/.env.example

# Override docker compose local (machine-spécifique : endpoint LLM, ports...).
docker-compose.override.yml

# Données et logs générés par Airflow (non versionnés)
raw_files/
clean_data/
logs/

# Données de monitoring générées (référence/courant pour /evaluate)
data/monitoring/

# Les artefacts versionnés par DVC sont ignorés via des .gitignore locaux
# générés par DVC (ex. data/processed/.gitignore). Ne pas ignorer ici les
# dossiers entiers : les fichiers .dvc et .gitignore locaux DOIVENT être commités.
